#include <iostream>
#include <cstdio>
#include <vector>
#include <cmath>
#include <string>
using namespace std;

int main()
{
	ios::sync_with_stdio(false);
	cin.tie(nullptr);

	string s;
	cin >> s;
	int n = s.size();
	vector<int> cst(n);
	for (int i = 0; i < n; i++) cin >> cst[i];

	vector<int> lst(7, 0), curr(7, 0);
	int ans = 0, totalcst = 0;
	for (int i = 0; i < n; i++)
	{
		totalcst += cst[i], curr[0] += cst[i];
		if (s[i] == 'e')
		{
			if (curr[5] > 0)
			{
				curr[6] = max(curr[6], curr[5] + cst[i]);
				curr[2] = max(curr[2], curr[1] + cst[i]);
				lst = curr;
				curr = vector<int>(7, 0);
				curr[0] = lst[6];
				lst[0] = 0;
				ans++;
			}

			else if (curr[1] > 0)
			{
				curr[2] = max(curr[2], curr[1] + cst[i]);
				lst[2] = 0;
				if (ans > 0)
				{
					lst[6] = max(lst[6], lst[5] + cst[i]);
					curr[0] = max(curr[0], lst[6]);
				}
			}

			else if (ans > 0)
			{
				lst[6] = max(lst[6], lst[5] + cst[i]);
				curr[0] = max(curr[0], lst[6]);
				lst[2] = max(lst[2], lst[1] + cst[i]);
			}
		}

		else if (s[i] == 'i')
		{
			if (curr[4] > 0)
			{
				curr[5] = max(curr[5], curr[4] + cst[i]);
				lst[5] = 0;
			}

			else if (ans > 0) lst[5] = max(lst[5], lst[4] + cst[i]);
		}

		else if (s[i] == 's')
		{
			if (curr[3] > 0)
			{
				curr[4] = max(curr[4], curr[3] + cst[i]);
				lst[4] = 0;
				curr[3] = max(curr[3], curr[2] + cst[i]);
			}

			else if (curr[2] > 0)
			{
				curr[3] = max(curr[3], curr[2] + cst[i]);
				if (ans > 0) lst[4] = max(lst[4], lst[3] + cst[i]);
				lst[3] = 0;
			}

			else if (ans > 0)
			{
				lst[4] = max(lst[4], lst[3] + cst[i]);
				lst[3] = max(lst[3], lst[2] + cst[i]);
			}
		}

		else if (s[i] == 'b') curr[1] = max(curr[1], curr[0]), lst[1] = 0;
	}

	cout << ans << "\n" << totalcst - curr[0];
}
